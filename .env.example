# MySQL конфигурация
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=routes_db
DB_TABLE=routes

# Маршрутизация
TARGET_GW=10.8.1.1
ROUTE_INTERFACE=tun0

# API конфигурация
API_PORT=3000
API_KEY=change-me-to-secure-key

# Синхронизация
SYNC_INTERVAL_MS=60000
AUTO_SYNC_ENABLED=true

# Логирование (debug, info, warn, error)
LOG_LEVEL=info